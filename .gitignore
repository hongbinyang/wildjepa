wandb/
outputs/
multirun/
logs/
*.log

# Notebooks
.ipynb_checkpoints/

# OS
.DS_Store

# Hydra
.hydra/

# Leftover cruft from a sandbox filesystem quirk during initial git setup --
# harmless stray directories, never meant to be tracked. Safe to delete.
.git_broken/
.git_broken2/
